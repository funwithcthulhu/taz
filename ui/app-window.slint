import { Button, CheckBox, ComboBox, LineEdit, ScrollView } from "std-widgets.slint";

export struct BrowseRow { title: string, teaser: string, section: string, source: string, source_label: string, url: string, selected: bool, saved: bool }
export struct BulkSectionRow { label: string, selected: bool }
export struct LibraryRow { id: int, title: string, section: string, heading: string, date: string, words: string, difficulty: int, url: string, uploaded: bool, paywalled: bool, selected: bool, confirming-delete: bool, viewing: bool }
export struct StatCard { label: string, value: string }
export struct ActivityRow { kind: string, message: string, detail: string }
export struct FailedRow { label: string, detail: string, retryable: bool }

component Panel inherits Rectangle {
    in property <brush> panel-background: #151c28;
    in property <brush> panel-border: #263149;
    background: panel-background;
    border-color: panel-border;
    border-width: 1px;
    border-radius: 12px;
}

// Small text button for inline actions
component TextBtn inherits Rectangle {
    in property <string> label;
    in property <brush> text-color: #7ea8e0;
    in property <bool> enabled: true;
    callback clicked;
    height: 20px;
    width: btn-text.preferred-width + 12px;
    border-radius: 4px;
    background: root.enabled && ta.has-hover ? #ffffff10 : transparent;
    btn-text := Text { text: root.label; color: root.enabled ? (ta.has-hover ? #ffffff : root.text-color) : #607089; font-size: 11px; font-weight: 600; horizontal-alignment: center; vertical-alignment: center; }
    ta := TouchArea { enabled: root.enabled; mouse-cursor: root.enabled ? pointer : default; clicked => { root.clicked(); } }
}

// Tiny preset button for date range shortcuts
component PresetBtn inherits Rectangle {
    in property <string> label;
    callback clicked;
    height: 22px;
    width: btn-text.preferred-width + 10px;
    border-radius: 4px;
    background: ta.has-hover ? #ffffff10 : transparent;
    btn-text := Text { text: root.label; color: ta.has-hover ? #ccd6e6 : #8190ab; font-size: 10px; font-weight: 600; horizontal-alignment: center; vertical-alignment: center; }
    ta := TouchArea { mouse-cursor: pointer; clicked => { root.clicked(); } }
}

export component AppWindow inherits Window {
    title: "Taz Reader";
    icon: @image-url("../assets/taz.png");
    preferred-width: 1200px;
    preferred-height: 760px;
    min-width: 980px;
    min-height: 660px;
    background: #11151d;

    in-out property <int> page-index: 0;
    in-out property <int> browse-section-index: 0;
    in-out property <bool> browse-only-new: true;
    in-out property <string> browse-date-from: "";
    in-out property <string> browse-date-to: "";
    in-out property <string> bulk-max-articles: "60";
    in-out property <string> bulk-per-section-cap: "30";
    in-out property <string> bulk-stop-after-old: "12";
    in-out property <string> library-search: "";
    in-out property <int> library-heading-index: 0;
    in-out property <int> library-section-index: 0;
    in-out property <int> library-sort-index: 0;
    in-out property <bool> library-only-not-uploaded: false;
    in-out property <string> library-min-words: "";
    in-out property <string> library-max-words: "";
    in-out property <bool> library-duplicate-only: false;
    in-out property <int> library-filter-preset-index: 0;
    in-out property <int> article-density-index: 0;
    in-out property <bool> show-library-filters: true;
    in-out property <bool> show-upload-tools: true;
    in-out property <int> lingq-collection-index: 0;
    in-out property <string> lingq-min-words: "";
    in-out property <string> lingq-max-words: "";
    in-out property <bool> lingq-only-not-uploaded: true;
    in-out property <bool> lingq-connected: false;
    in-out property <bool> show-lingq-settings: false;
    in-out property <bool> show-bulk-sections: false;
    in property <string> bulk-sections-label: "Sections";
    in-out property <string> lingq-token: "";
    in-out property <string> lingq-username: "";
    in-out property <string> lingq-password: "";
    in-out property <bool> preview-wide: false;
    in-out property <string> taz-search-query: "";

    in property <[string]> browse-section-labels;
    in property <[BrowseRow]> browse-rows;
    in property <[BulkSectionRow]> bulk-section-rows;
    in property <[LibraryRow]> library-rows;
    in property <[StatCard]> stat-cards;
    in property <[string]> heading-labels;
    in property <[string]> section-labels;
    in property <[string]> sort-labels;
    in property <[string]> filter-preset-labels;
    in property <[string]> density-labels;
    in property <[string]> collection-labels;
    in property <string> status-message: "";
    in property <string> browse-summary: "";
    in property <string> library-summary: "";
    in property <string> preview-title: "";
    in property <string> preview-meta: "";
    in property <string> preview-body: "";
    in property <string> preview-url: "";
    in property <bool> preview-has-article: false;
    in property <string> progress-label: "";
    in property <float> progress-value: 0;
    in property <bool> progress-visible: false;
    in property <string> queue-label: "";
    in property <[ActivityRow]> activity-rows;
    in property <[FailedRow]> failed-rows;
    in property <string> browse-count: "";
    in property <string> library-count: "";
    in-out property <bool> auto-fetch-on-startup: false;

    callback switch-page(int);
    callback browse-set-section-index(int);
    callback browse-set-only-new(bool);
    callback browse-refresh();
    callback browse-load-more();
    callback browse-set-date-from(string);
    callback browse-set-date-to(string);
    callback browse-toggle-article(int);
    callback browse-select-all-new();
    callback browse-clear-selection();
    callback browse-save-selected();
    callback browse-open-url(string);
    callback browse-save-single(string);
    callback browse-toggle-bulk-section(int);
    callback browse-bulk-select-all();
    callback browse-bulk-clear();
    callback browse-run-bulk-fetch();
    callback library-apply-filters();
    callback library-set-only-not-uploaded(bool);
    callback library-set-min-words(string);
    callback library-set-max-words(string);
    callback library-set-duplicate-only(bool);
    callback library-apply-preset(int);
    callback set-article-density(int);
    callback open-library-folder();
    callback library-toggle-select(int);
    callback library-select-article(int);
    callback library-delete-article(int);
    callback library-open-url(string);
    callback library-select-visible-for-upload();
    callback library-clear-upload-selection();
    callback library-upload-selected();
    callback library-delete-selected();
    callback lingq-open-settings();
    callback lingq-set-only-not-uploaded(bool);
    callback lingq-set-min-words(string);
    callback lingq-set-max-words(string);
    callback lingq-close-settings();
    callback lingq-save-token();
    callback lingq-login();
    callback lingq-refresh-collections();
    callback lingq-disconnect();
    callback lingq-sync-status();
    callback library-search-accepted();
    callback browse-set-date-preset(int);
    callback toggle-preview-width();
    callback taz-set-search-query(string);
    callback taz-search();
    callback cancel-operation();
    callback retry-failed-items();
    callback clear-failed-items();
    callback library-key-up();
    callback library-key-down();
    callback library-key-space();

    Rectangle {
        background: #11151d;

        HorizontalLayout {
            spacing: 0px;

            // ── Sidebar ──
            Rectangle {
                width: 210px;
                background: #171d29;
                border-width: 1px;
                border-color: #273247;

                VerticalLayout {
                    padding: 14px;
                    spacing: 10px;

                    Panel {
                        height: 48px;
                        panel-background: #c61f3f;
                        panel-border: #c61f3f;
                        VerticalLayout {
                            padding: 12px;
                            Text { text: "Taz Reader"; color: white; font-size: 19px; font-weight: 800; }
                        }
                    }

                    // Browse nav button with badge
                    Panel {
                        height: 40px;
                        panel-background: root.page-index == 0 ? #2c3d5e : (browse-nav-ta.has-hover ? #232e42 : #1b2230);
                        panel-border: root.page-index == 0 ? #44608e : #1b2230;
                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 12px;
                            alignment: center;
                            Text { text: "Browse"; color: white; horizontal-alignment: left; vertical-alignment: center; font-size: 15px; font-weight: 700; horizontal-stretch: 1; }
                            if root.browse-count != "" : VerticalLayout {
                                alignment: center;
                                Rectangle {
                                    width: max(20px, browse-badge.preferred-width + 12px);
                                    height: 20px;
                                    border-radius: 10px;
                                    background: #2d4a6e;
                                    browse-badge := Text { text: root.browse-count; color: #8fb8e8; font-size: 11px; font-weight: 700; width: parent.width; height: parent.height; horizontal-alignment: center; vertical-alignment: center; }
                                }
                            }
                        }
                        browse-nav-ta := TouchArea { mouse-cursor: pointer; clicked => { root.switch-page(0); } }
                    }

                    // Library nav button with badge
                    Panel {
                        height: 40px;
                        panel-background: root.page-index == 1 ? #2c3d5e : (library-nav-ta.has-hover ? #232e42 : #1b2230);
                        panel-border: root.page-index == 1 ? #44608e : #1b2230;
                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 12px;
                            alignment: center;
                            Text { text: "Library + LingQ"; color: white; horizontal-alignment: left; vertical-alignment: center; font-size: 15px; font-weight: 700; horizontal-stretch: 1; }
                            if root.library-count != "" : VerticalLayout {
                                alignment: center;
                                Rectangle {
                                    width: max(20px, library-badge.preferred-width + 12px);
                                    height: 20px;
                                    border-radius: 10px;
                                    background: #2d4a6e;
                                    library-badge := Text { text: root.library-count; color: #8fb8e8; font-size: 11px; font-weight: 700; width: parent.width; height: parent.height; horizontal-alignment: center; vertical-alignment: center; }
                                }
                            }
                        }
                        library-nav-ta := TouchArea { mouse-cursor: pointer; clicked => { root.switch-page(1); } }
                    }

                    Panel {
                        height: 100px;
                        VerticalLayout {
                            padding: 10px;
                            spacing: 4px;
                            Text { text: "Status"; color: #8190ab; font-size: 12px; font-weight: 700; }
                            Text { text: root.status-message; color: #eef4ff; wrap: word-wrap; font-size: 12px; overflow: elide; }
                        }
                    }

                    if root.progress-visible : Panel {
                        height: root.queue-label == "" ? 76px : 92px;
                        VerticalLayout {
                            padding: 10px;
                            spacing: 6px;
                            Text { text: root.progress-label; color: #eef4ff; font-size: 11px; wrap: word-wrap; overflow: elide; }
                            if root.queue-label != "" : Text { text: root.queue-label; color: #8fa0bd; font-size: 10px; overflow: elide; }
                            Rectangle {
                                height: 6px;
                                border-radius: 999px;
                                background: #273247;
                                Rectangle {
                                    height: parent.height;
                                    width: parent.width * root.progress-value;
                                    animate width { duration: 300ms; easing: ease-in-out; }
                                    border-radius: 999px;
                                    background: #5aa0ff;
                                }
                            }
                            HorizontalLayout {
                                Rectangle { }
                                cancel-btn := Rectangle {
                                    width: cancel-text.preferred-width + 16px;
                                    height: 22px;
                                    border-radius: 6px;
                                    background: cancel-ta.has-hover ? #3a1520 : #2a1018;
                                    border-color: #e06070;
                                    border-width: 1px;
                                    cancel-text := Text { text: "Cancel"; color: cancel-ta.has-hover ? #ff6070 : #e06070; font-size: 11px; font-weight: 600; horizontal-alignment: center; vertical-alignment: center; }
                                    cancel-ta := TouchArea { mouse-cursor: pointer; clicked => { root.cancel-operation(); } }
                                }
                                Rectangle { }
                            }
                        }
                    }

                    if root.failed-rows.length > 0 : Panel {
                        height: 116px;
                        VerticalLayout {
                            padding: 10px;
                            spacing: 5px;
                            HorizontalLayout {
                                Text { text: "Retry list"; color: #ffb3be; font-size: 12px; font-weight: 800; horizontal-stretch: 1; }
                                Text { text: root.failed-rows.length; color: #ffb3be; font-size: 12px; font-weight: 800; }
                            }
                            ScrollView {
                                height: 42px;
                                VerticalLayout {
                                    spacing: 2px;
                                    for failed in root.failed-rows : Text {
                                        text: failed.label;
                                        color: failed.retryable ? #eef4ff : #8b95aa;
                                        font-size: 10px;
                                        overflow: elide;
                                    }
                                }
                            }
                            HorizontalLayout {
                                spacing: 5px;
                                Button { text: "Retry"; clicked => { root.retry-failed-items(); } }
                                Button { text: "Clear"; clicked => { root.clear-failed-items(); } }
                            }
                        }
                    }

                    Panel {
                        height: 118px;
                        VerticalLayout {
                            padding: 10px;
                            spacing: 4px;
                            for stat in root.stat-cards : HorizontalLayout {
                                spacing: 6px;
                                Text { text: stat.label + ":"; color: #7f8ca7; font-size: 12px; font-weight: 700; width: 105px; horizontal-alignment: left; }
                                Text { text: stat.value; color: white; font-size: 12px; font-weight: 800; horizontal-alignment: right; horizontal-stretch: 1; }
                            }
                        }
                    }

                    Panel {
                        vertical-stretch: 1;
                        VerticalLayout {
                            padding: 10px;
                            spacing: 5px;
                            Text { text: "Activity"; color: #8190ab; font-size: 12px; font-weight: 800; }
                            ScrollView {
                                vertical-stretch: 1;
                                VerticalLayout {
                                    spacing: 5px;
                                    if root.activity-rows.length == 0 : Text { text: "No recent activity."; color: #66738b; font-size: 10px; }
                                    for item in root.activity-rows : VerticalLayout {
                                        spacing: 1px;
                                        Text { text: item.message; color: #eef4ff; font-size: 10px; font-weight: 700; overflow: elide; }
                                        Text { text: item.detail; color: #7d8aa4; font-size: 9px; overflow: elide; }
                                    }
                                }
                            }
                        }
                    }

                    Button { text: "LingQ Settings"; clicked => { root.lingq-open-settings(); } }
                }
            }

            // ── Main content area ──
            Rectangle {
                horizontal-stretch: 1;
                background: #11151d;
                clip: true;

                VerticalLayout {
                    padding: 10px;
                    spacing: 6px;

                    // ════════════════════════════════════
                    //  BROWSE PAGE
                    // ════════════════════════════════════
                    if root.page-index == 0 : VerticalLayout {
                        spacing: 6px;
                        horizontal-stretch: 1;
                        vertical-stretch: 1;

                        // Browse toolbar — single row
                        Panel {
                            height: 56px;
                            clip: true;
                            VerticalLayout {
                                padding: 8px;
                                spacing: 2px;
                                HorizontalLayout {
                                    spacing: 6px;
                                    ComboBox {
                                        model: root.browse-section-labels;
                                        current-index <=> root.browse-section-index;
                                        min-width: 180px;
                                        selected(_) => { root.browse-set-section-index(root.browse-section-index); }
                                    }
                                    CheckBox {
                                        text: "Only new";
                                        checked <=> root.browse-only-new;
                                        toggled => { root.browse-set-only-new(self.checked); }
                                    }
                                    Button { text: "Select all"; clicked => { root.browse-select-all-new(); } }
                                    Button { text: "Clear"; clicked => { root.browse-clear-selection(); } }
                                    Button { text: "Save selected"; enabled: !root.progress-visible; clicked => { root.browse-save-selected(); } }
                                    Rectangle { }
                                    Button { text: "Refresh"; clicked => { root.browse-refresh(); } }
                                    Button { text: "More"; clicked => { root.browse-load-more(); } }
                                }
                                Text { text: root.browse-summary; color: #9aa6be; font-size: 11px; }
                            }
                        }

                        // taz Search
                        Panel {
                            height: 44px;
                            clip: true;
                            HorizontalLayout {
                                padding: 6px;
                                padding-left: 10px;
                                padding-right: 10px;
                                spacing: 6px;
                                Text { text: "Search taz.de"; color: #8190ab; font-size: 11px; vertical-alignment: center; }
                                taz-search-input := LineEdit {
                                    text <=> root.taz-search-query;
                                    placeholder-text: "e.g. Klimawandel, Ukraine, Migration...";
                                    horizontal-stretch: 1;
                                    edited => { root.taz-set-search-query(self.text); }
                                    accepted => { root.taz-search(); }
                                }
                                Text { text: "From"; color: #8190ab; font-size: 11px; vertical-alignment: center; }
                                LineEdit {
                                    text <=> root.browse-date-from;
                                    placeholder-text: "YYYY-MM-DD";
                                    min-width: 94px;
                                    max-width: 94px;
                                    edited => { root.browse-set-date-from(self.text); }
                                    accepted => { root.taz-search(); }
                                }
                                Text { text: "To"; color: #8190ab; font-size: 11px; vertical-alignment: center; }
                                LineEdit {
                                    text <=> root.browse-date-to;
                                    placeholder-text: "YYYY-MM-DD";
                                    min-width: 94px;
                                    max-width: 94px;
                                    edited => { root.browse-set-date-to(self.text); }
                                    accepted => { root.taz-search(); }
                                }
                                Button { text: "Search"; clicked => { root.taz-search(); } }
                            }
                        }

                        // Bulk Fetch
                        Panel {
                            height: root.show-bulk-sections ? 140px : 66px;
                            clip: true;
                            VerticalLayout {
                                padding: 6px;
                                padding-left: 10px;
                                padding-right: 10px;
                                spacing: 4px;
                                HorizontalLayout {
                                    spacing: 5px;
                                    Text { text: "Bulk"; color: white; font-size: 13px; font-weight: 800; vertical-alignment: center; }
                                    Text { text: "From"; color: #8190ab; font-size: 11px; vertical-alignment: center; }
                                    LineEdit { text <=> root.browse-date-from; placeholder-text: "YYYY-MM-DD"; min-width: 100px; max-width: 100px; edited => { root.browse-set-date-from(self.text); } }
                                    Text { text: "To"; color: #8190ab; font-size: 11px; vertical-alignment: center; }
                                    LineEdit { text <=> root.browse-date-to; placeholder-text: "YYYY-MM-DD"; min-width: 100px; max-width: 100px; edited => { root.browse-set-date-to(self.text); } }
                                    Text { text: "Max"; color: #8190ab; font-size: 11px; vertical-alignment: center; }
                                    LineEdit { text <=> root.bulk-max-articles; placeholder-text: "60"; min-width: 40px; max-width: 40px; }
                                    Text { text: "Per sect"; color: #8190ab; font-size: 11px; vertical-alignment: center; }
                                    LineEdit { text <=> root.bulk-per-section-cap; placeholder-text: "30"; min-width: 40px; max-width: 40px; }
                                    Text { text: "Stop after"; color: #8190ab; font-size: 11px; vertical-alignment: center; }
                                    LineEdit { text <=> root.bulk-stop-after-old; placeholder-text: "12"; min-width: 36px; max-width: 36px; }
                                    Button { text: root.bulk-sections-label; clicked => { root.show-bulk-sections = !root.show-bulk-sections; } min-width: 100px; }
                                    Button { text: "All"; clicked => { root.browse-bulk-select-all(); } }
                                    Button { text: "None"; clicked => { root.browse-bulk-clear(); } }
                                    Button { text: "Fetch"; enabled: !root.progress-visible; clicked => { root.browse-run-bulk-fetch(); } }
                                    Rectangle { }
                                }
                                // Date preset shortcuts
                                HorizontalLayout {
                                    spacing: 4px;
                                    Text { text: "Quick:"; color: #6b7a94; font-size: 10px; vertical-alignment: center; }
                                    PresetBtn { label: "7d"; clicked => { root.browse-set-date-preset(0); } }
                                    PresetBtn { label: "30d"; clicked => { root.browse-set-date-preset(1); } }
                                    PresetBtn { label: "3mo"; clicked => { root.browse-set-date-preset(2); } }
                                    PresetBtn { label: "This year"; clicked => { root.browse-set-date-preset(3); } }
                                    PresetBtn { label: "Last year"; clicked => { root.browse-set-date-preset(4); } }
                                    Rectangle { horizontal-stretch: 1; }
                                    CheckBox { text: "Auto-fetch on startup"; checked <=> root.auto-fetch-on-startup; }
                                }
                                if root.show-bulk-sections : Panel {
                                    panel-background: #1b2230;
                                    panel-border: #2a3550;
                                    clip: true;
                                    vertical-stretch: 1;
                                    ScrollView {
                                        width: parent.width;
                                        height: parent.height;
                                        VerticalLayout {
                                            padding: 4px;
                                            spacing: 2px;
                                            for section[index] in root.bulk-section-rows : HorizontalLayout {
                                                height: 22px;
                                                padding-left: 6px;
                                                spacing: 6px;
                                                CheckBox { checked: section.selected; toggled => { root.browse-toggle-bulk-section(index); } }
                                                Text { text: section.label; color: #eef4ff; vertical-alignment: center; font-size: 11px; }
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        // Browse article list
                        Panel {
                            horizontal-stretch: 1;
                            vertical-stretch: 1;
                            clip: true;
                            ScrollView {
                                width: parent.width;
                                height: parent.height;
                                VerticalLayout {
                                    padding: 6px;
                                    spacing: 5px;

                                    // Empty state
                                    if root.browse-rows.length == 0 : Rectangle {
                                        height: 80px;
                                        VerticalLayout {
                                            alignment: center;
                                            Text { text: "No articles to show."; color: #6b7a94; font-size: 14px; horizontal-alignment: center; }
                                            Text { text: "Select a section and click Refresh to browse taz.de."; color: #4e5d76; font-size: 12px; horizontal-alignment: center; }
                                        }
                                    }

                                    for article[index] in root.browse-rows : Panel {
                                        min-height: 72px;
                                        panel-background: article.selected ? #20324d : #192232;
                                        panel-border: article.selected ? #5aa0ff : #2b364f;
                                        border-radius: 8px;
                                        HorizontalLayout {
                                            padding: 8px;
                                            spacing: 8px;
                                            CheckBox { checked: article.selected; toggled => { root.browse-toggle-article(index); } }
                                            VerticalLayout {
                                                horizontal-stretch: 1;
                                                spacing: 2px;
                                                // Title row with metadata inline
                                                HorizontalLayout {
                                                    spacing: 8px;
                                                    Text { text: article.title; color: white; font-size: 14px; font-weight: 750; horizontal-stretch: 1; overflow: elide; }
                                                    Text { text: article.section; color: #6e8bb5; font-size: 11px; vertical-alignment: center; }
                                                    Text { text: article.saved ? "Saved" : "New"; color: article.saved ? #7ce2a4 : #ffb6c1; font-size: 11px; vertical-alignment: center; }
                                                }
                                                Text { text: article.teaser; color: #8f9db7; font-size: 12px; wrap: word-wrap; }
                                            }
                                            // Compact action column
                                            VerticalLayout {
                                                spacing: 2px;
                                                alignment: center;
                                                TextBtn { label: "Open"; clicked => { root.browse-open-url(article.url); } }
                                                TextBtn { label: article.saved ? "Resave" : "Save"; enabled: !root.progress-visible; clicked => { root.browse-save-single(article.url); } }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // ════════════════════════════════════
                    //  LIBRARY + LINGQ PAGE
                    // ════════════════════════════════════
                    if root.page-index == 1 : VerticalLayout {
                        spacing: 6px;
                        horizontal-stretch: 1;
                        vertical-stretch: 1;

                        // Library filters — always visible, single row
                        Panel {
                            height: 38px;
                            HorizontalLayout {
                                padding: 6px;
                                padding-left: 10px;
                                padding-right: 10px;
                                spacing: 5px;
                                Text { text: "Filters"; color: #8190ab; font-size: 12px; font-weight: 700; vertical-alignment: center; }
                                LineEdit { text <=> root.library-search; placeholder-text: "Search (Enter to apply)"; min-width: 160px; accepted => { root.library-search-accepted(); } }
                                ComboBox { model: root.heading-labels; current-index <=> root.library-heading-index; min-width: 110px; }
                                ComboBox { model: root.section-labels; current-index <=> root.library-section-index; min-width: 110px; }
                                ComboBox { model: root.sort-labels; current-index <=> root.library-sort-index; min-width: 90px; max-width: 90px; }
                                LineEdit {
                                    text <=> root.library-min-words;
                                    placeholder-text: "Min words";
                                    min-width: 72px;
                                    max-width: 72px;
                                    edited => { root.library-set-min-words(self.text); }
                                }
                                LineEdit {
                                    text <=> root.library-max-words;
                                    placeholder-text: "Max words";
                                    min-width: 72px;
                                    max-width: 72px;
                                    edited => { root.library-set-max-words(self.text); }
                                }
                                CheckBox {
                                    text: "Not uploaded";
                                    checked <=> root.library-only-not-uploaded;
                                    toggled => { root.library-set-only-not-uploaded(self.checked); }
                                }
                                Button { text: "Apply"; clicked => { root.library-apply-filters(); } }
                                Rectangle { }
                            }
                        }

                        // LingQ upload — always visible, single row
                        Panel {
                            height: 38px;
                            HorizontalLayout {
                                padding: 6px;
                                padding-left: 10px;
                                padding-right: 10px;
                                spacing: 5px;
                                Text { text: "LingQ"; color: #8190ab; font-size: 12px; font-weight: 700; vertical-alignment: center; }
                                Rectangle {
                                    width: conn-label.preferred-width + 18px;
                                    height: 20px;
                                    border-radius: 10px;
                                    background: root.lingq-connected ? #1a3328 : #33202a;
                                    conn-label := Text {
                                        text: root.lingq-connected ? "Connected" : "Disconnected";
                                        color: root.lingq-connected ? #7ce2a4 : #e06070;
                                        font-size: 10px;
                                        font-weight: 600;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                                ComboBox {
                                    model: root.collection-labels;
                                    current-index <=> root.lingq-collection-index;
                                    min-width: 220px;
                                    max-width: 320px;
                                    preferred-width: 280px;
                                }
                                LineEdit {
                                    text <=> root.lingq-min-words;
                                    placeholder-text: "Min words";
                                    min-width: 72px;
                                    max-width: 72px;
                                    edited => { root.lingq-set-min-words(self.text); }
                                }
                                LineEdit {
                                    text <=> root.lingq-max-words;
                                    placeholder-text: "Max words";
                                    min-width: 72px;
                                    max-width: 72px;
                                    edited => { root.lingq-set-max-words(self.text); }
                                }
                                CheckBox {
                                    text: "Not uploaded";
                                    checked <=> root.lingq-only-not-uploaded;
                                    toggled => { root.lingq-set-only-not-uploaded(self.checked); }
                                }
                                Button { text: "Select visible"; clicked => { root.library-select-visible-for-upload(); } }
                                Button { text: "Clear"; clicked => { root.library-clear-upload-selection(); } }
                                Button { text: "Delete Selected"; clicked => { root.library-delete-selected(); } }
                                Button { text: "Upload"; enabled: !root.progress-visible; clicked => { root.library-upload-selected(); } }
                                Button { text: "Sync status"; enabled: !root.progress-visible; clicked => { root.lingq-sync-status(); } }
                                Rectangle { }
                                Button { text: "Settings"; clicked => { root.lingq-open-settings(); } min-width: 60px; }
                            }
                        }

                        Panel {
                            height: 34px;
                            HorizontalLayout {
                                padding: 5px;
                                padding-left: 10px;
                                padding-right: 10px;
                                spacing: 6px;
                                Text { text: "Tools"; color: #8190ab; font-size: 12px; font-weight: 700; vertical-alignment: center; }
                                ComboBox {
                                    model: root.filter-preset-labels;
                                    current-index <=> root.library-filter-preset-index;
                                    min-width: 170px;
                                    selected(_) => { root.library-apply-preset(root.library-filter-preset-index); }
                                }
                                ComboBox {
                                    model: root.density-labels;
                                    current-index <=> root.article-density-index;
                                    min-width: 120px;
                                    max-width: 130px;
                                    selected(_) => { root.set-article-density(root.article-density-index); }
                                }
                                CheckBox {
                                    text: "Duplicates";
                                    checked <=> root.library-duplicate-only;
                                    toggled => { root.library-set-duplicate-only(self.checked); }
                                }
                                Button { text: "Open library folder"; clicked => { root.open-library-folder(); } }
                                Rectangle { }
                            }
                        }

                        Text { text: root.library-summary; color: #9aa6be; font-size: 11px; }

                        // Library article list + preview split
                        HorizontalLayout {
                            horizontal-stretch: 1;
                            vertical-stretch: 1;
                            spacing: 6px;

                            // Article list
                            Panel {
                                horizontal-stretch: 1;
                                vertical-stretch: 1;
                                clip: true;
                                library-focus := FocusScope {
                                    key-pressed(event) => {
                                        if (event.text == Key.UpArrow) {
                                            root.library-key-up();
                                            return accept;
                                        }
                                        if (event.text == Key.DownArrow) {
                                            root.library-key-down();
                                            return accept;
                                        }
                                        if (event.text == " ") {
                                            root.library-key-space();
                                            return accept;
                                        }
                                        return reject;
                                    }
                                }
                                // Click anywhere in the list to grab focus
                                TouchArea { clicked => { library-focus.focus(); } }
                                ScrollView {
                                    width: parent.width;
                                    height: parent.height;
                                    VerticalLayout {
                                        padding: 6px;
                                        spacing: 4px;

                                        // Empty state
                                        if root.library-rows.length == 0 : Rectangle {
                                            height: 80px;
                                            VerticalLayout {
                                                alignment: center;
                                                Text { text: "No saved articles."; color: #6b7a94; font-size: 14px; horizontal-alignment: center; }
                                                Text { text: "Browse and save articles from the Browse page."; color: #4e5d76; font-size: 12px; horizontal-alignment: center; }
                                            }
                                        }

                                        for article[index] in root.library-rows : Panel {
                                            min-height: root.article-density-index == 0 ? 42px : 56px;
                                            panel-background: article.viewing ? #1e2f4a : (article.selected ? #20324d : #192232);
                                            panel-border: article.viewing ? #4488cc : (article.selected ? #5aa0ff : #2b364f);
                                            border-radius: 8px;
                                            HorizontalLayout {
                                                padding: 6px;
                                                spacing: 6px;
                                                // Viewing accent bar
                                                if article.viewing : Rectangle {
                                                    width: 3px;
                                                    border-radius: 2px;
                                                    background: #5aa0ff;
                                                }
                                                CheckBox { checked: article.selected; toggled => { root.library-toggle-select(index); } }
                                                Rectangle {
                                                    horizontal-stretch: 1;
                                                    VerticalLayout {
                                                        spacing: 1px;
                                                        HorizontalLayout {
                                                            spacing: 8px;
                                                            Text { text: article.title; color: white; font-size: root.article-density-index == 0 ? 12px : 14px; font-weight: 760; horizontal-stretch: 1; overflow: elide; }
                                                            Text { text: article.words + "w"; color: #6e8bb5; font-size: 11px; vertical-alignment: center; }
                                                            Rectangle {
                                                                width: 22px; height: 16px; border-radius: 4px;
                                                                background: article.difficulty <= 1 ? #2d6a4f : article.difficulty == 2 ? #40916c : article.difficulty == 3 ? #e9c46a : article.difficulty == 4 ? #e76f51 : #d62828;
                                                                Text { text: article.difficulty; color: article.difficulty <= 2 ? white : article.difficulty == 3 ? #1a1a2e : white; font-size: 10px; font-weight: 800; horizontal-alignment: center; vertical-alignment: center; }
                                                            }
                                                            Text { text: article.date; color: #6e8bb5; font-size: 11px; vertical-alignment: center; }
                                                            if article.paywalled : Text { text: "Paywall"; color: #e76f51; font-size: 11px; font-weight: 700; vertical-alignment: center; }
                                                            Text { text: article.uploaded ? "LingQ" : "Local"; color: article.uploaded ? #7ce2a4 : #9aa6be; font-size: 11px; vertical-alignment: center; }
                                                        }
                                                        Text { text: article.section; color: #6e8bb5; font-size: root.article-density-index == 0 ? 10px : 11px; }
                                                    }
                                                    TouchArea { mouse-cursor: pointer; clicked => { root.library-select-article(index); } }
                                                }
                                                // Compact inline actions
                                                VerticalLayout {
                                                    spacing: 1px;
                                                    alignment: center;
                                                    TextBtn { label: "Open"; clicked => { root.library-open-url(article.url); } }
                                                    TextBtn {
                                                        label: article.confirming-delete ? "Sure?" : "Delete";
                                                        text-color: article.confirming-delete ? #ff4455 : #e06070;
                                                        clicked => { root.library-delete-article(index); }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }

                            // Preview pane
                            Panel {
                                width: root.preview-wide ? 520px : 380px;
                                animate width { duration: 200ms; easing: ease-in-out; }
                                vertical-stretch: 1;
                                VerticalLayout {
                                    padding: 10px;
                                    spacing: 6px;
                                    HorizontalLayout {
                                        spacing: 6px;
                                        Text { text: root.preview-has-article ? root.preview-title : "Reading pane"; color: white; font-size: 16px; font-weight: 800; wrap: word-wrap; horizontal-stretch: 1; }
                                        TextBtn {
                                            label: root.preview-wide ? "Narrow" : "Wide";
                                            text-color: #6b7a94;
                                            clicked => { root.toggle-preview-width(); }
                                        }
                                    }
                                    Text { text: root.preview-has-article ? root.preview-meta : "Select a saved article to preview."; color: #9aa6be; wrap: word-wrap; font-size: 12px; }
                                    if root.preview-has-article : Button { text: "Open original"; clicked => { root.library-open-url(root.preview-url); } max-width: 140px; }
                                    Panel {
                                        panel-background: #1b2230;
                                        panel-border: #2a3550;
                                        vertical-stretch: 1;
                                        clip: true;
                                        ScrollView {
                                            width: parent.width;
                                            height: parent.height;
                                            viewport-width: self.width;
                                            VerticalLayout {
                                                padding: 10px;
                                                Text {
                                                    text: root.preview-body;
                                                    color: #eef4ff;
                                                    wrap: word-wrap;
                                                    font-size: 13px;
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        // ── LingQ Settings Modal ──
        if root.show-lingq-settings : Rectangle {
            background: #00000088;
            // Backdrop click-to-close
            TouchArea {
                clicked => { root.lingq-close-settings(); }
            }
            HorizontalLayout {
                Rectangle { }
                Panel {
                    width: 480px;
                    height: 460px;
                    y: 48px;
                    panel-background: #182131;
                    panel-border: #2d3a56;
                    // Block clicks from propagating to backdrop
                    TouchArea { }
                    VerticalLayout {
                        padding: 18px;
                        spacing: 10px;
                        HorizontalLayout {
                            Text { text: "LingQ Settings"; color: white; font-size: 22px; font-weight: 800; }
                            Rectangle { }
                            Button { text: "Close"; clicked => { root.lingq-close-settings(); } }
                        }
                        Text { text: "Use a token or log in with your LingQ account to refresh courses."; color: #9aa6be; wrap: word-wrap; font-size: 13px; }
                        Text { text: "API token"; color: #d6e0f2; font-size: 13px; }
                        LineEdit { text <=> root.lingq-token; input-type: password; }
                        HorizontalLayout {
                            spacing: 8px;
                            Button { text: "Save token"; clicked => { root.lingq-save-token(); } }
                            Button { text: "Refresh courses"; clicked => { root.lingq-refresh-collections(); } }
                            Button { text: "Disconnect"; clicked => { root.lingq-disconnect(); } }
                        }
                        Rectangle { height: 1px; background: #2d3a56; }
                        Text { text: "Username or email"; color: #d6e0f2; font-size: 13px; }
                        LineEdit { text <=> root.lingq-username; }
                        Text { text: "Password"; color: #d6e0f2; font-size: 13px; }
                        LineEdit { text <=> root.lingq-password; input-type: password; }
                        Button { text: "Log in and save token"; clicked => { root.lingq-login(); } }
                    }
                }
                Rectangle { }
            }
        }
    }
}
